{
  "__inputs": [],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "11.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" }
  ],
  "annotations": { "list": [] },
  "description": "Community Waste Collection API — full-stack observability: HTTP, business events, database, worker, Go runtime, and process metrics.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "API Overview",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "unit": "reqps", "color": { "mode": "palette-classic" } },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 1 },
      "id": 1,
      "options": { "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total[5m])) by (path)",
          "legendFormat": "{{path}}",
          "refId": "A"
        }
      ],
      "title": "Request Rate by Path (RPS)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "unit": "percentunit", "max": 1, "min": 0, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 0.05 }, { "color": "red", "value": 0.1 }] } },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 1 },
      "id": 2,
      "options": { "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{status=~\"4..|5..\"}[5m])) by (path) / sum(rate(http_requests_total[5m])) by (path)",
          "legendFormat": "{{path}}",
          "refId": "A"
        }
      ],
      "title": "Error Rate by Path",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "unit": "s", "color": { "mode": "palette-classic" } },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 1 },
      "id": 3,
      "options": { "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(http_request_duration_seconds_bucket[5m])) by (le, path))",
          "legendFormat": "p50 {{path}}",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket[5m])) by (le, path))",
          "legendFormat": "p95 {{path}}",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(http_request_duration_seconds_bucket[5m])) by (le, path))",
          "legendFormat": "p99 {{path}}",
          "refId": "C"
        }
      ],
      "title": "Request Latency Percentiles",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "unit": "short" },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 9 },
      "id": 4,
      "options": { "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total[5m])) by (status)",
          "legendFormat": "HTTP {{status}}",
          "refId": "A"
        }
      ],
      "title": "Request Rate by Status Code",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "unit": "short" },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 9 },
      "id": 5,
      "options": { "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "rate(http_requests_total{status=\"429\"}[5m])",
          "legendFormat": "Rate Limit Rejections",
          "refId": "A"
        }
      ],
      "title": "Rate Limit Rejections (429/s)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "unit": "s" },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 9 },
      "id": 6,
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket[5m])) by (le, method))",
          "legendFormat": "p95 {{method}}",
          "refId": "A"
        }
      ],
      "title": "Latency p95 by HTTP Method",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 17 },
      "id": 101,
      "title": "Business Events",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "unit": "short", "color": { "mode": "palette-classic" } },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 18 },
      "id": 10,
      "targets": [
        {
          "expr": "rate(waste_pickups_created_total[5m])",
          "legendFormat": "Created ({{type}})",
          "refId": "A"
        }
      ],
      "title": "Pickups Created Rate by Type",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "unit": "short" },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 18 },
      "id": 11,
      "targets": [
        {
          "expr": "rate(waste_pickups_completed_total[5m])",
          "legendFormat": "Completed ({{type}})",
          "refId": "A"
        },
        {
          "expr": "rate(waste_pickups_canceled_total[5m])",
          "legendFormat": "Canceled ({{type}}/{{reason}})",
          "refId": "B"
        }
      ],
      "title": "Pickups Completed & Canceled Rate",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "unit": "short" },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 18 },
      "id": 12,
      "targets": [
        {
          "expr": "rate(waste_payments_created_total[5m])",
          "legendFormat": "Payments Created",
          "refId": "A"
        },
        {
          "expr": "rate(waste_payments_confirmed_total[5m])",
          "legendFormat": "Payments Confirmed",
          "refId": "B"
        },
        {
          "expr": "rate(waste_organic_auto_cancels_total[5m])",
          "legendFormat": "Organic Auto-Cancels",
          "refId": "C"
        }
      ],
      "title": "Payment & Auto-Cancel Events",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "unit": "short", "color": { "fixedColor": "blue", "mode": "fixed" } },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 26 },
      "id": 13,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        { "expr": "waste_pickups_created_total", "legendFormat": "", "refId": "A" }
      ],
      "title": "Total Pickups Created",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "unit": "short", "color": { "fixedColor": "green", "mode": "fixed" } },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 26 },
      "id": 14,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        { "expr": "waste_payments_confirmed_total", "legendFormat": "", "refId": "A" }
      ],
      "title": "Total Payments Confirmed",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "unit": "short", "color": { "fixedColor": "orange", "mode": "fixed" } },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 26 },
      "id": 15,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        { "expr": "waste_organic_auto_cancels_total", "legendFormat": "", "refId": "A" }
      ],
      "title": "Organic Auto-Cancels (total)",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "unit": "short", "color": { "fixedColor": "red", "mode": "fixed" } },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 26 },
      "id": 16,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        { "expr": "sum(waste_pickups_canceled_total)", "legendFormat": "", "refId": "A" }
      ],
      "title": "Total Pickups Canceled",
      "type": "stat"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 30 },
      "id": 102,
      "title": "Database Performance",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "unit": "s", "color": { "mode": "palette-classic" } },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 31 },
      "id": 20,
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(db_query_duration_seconds_bucket[5m])) by (le, table, operation))",
          "legendFormat": "p95 {{table}}.{{operation}}",
          "refId": "A"
        }
      ],
      "title": "DB Query Latency p95 by Table/Operation",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "unit": "ops", "color": { "mode": "palette-classic" } },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 31 },
      "id": 21,
      "targets": [
        {
          "expr": "sum(rate(db_query_duration_seconds_count[5m])) by (table, operation)",
          "legendFormat": "{{table}}.{{operation}}",
          "refId": "A"
        }
      ],
      "title": "DB Query Throughput (ops/s)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "unit": "short", "color": { "mode": "palette-classic" } },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 31 },
      "id": 22,
      "targets": [
        {
          "expr": "sum(rate(db_errors_total[5m])) by (table, operation)",
          "legendFormat": "{{table}}.{{operation}}",
          "refId": "A"
        }
      ],
      "title": "DB Errors Rate by Table/Operation",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "unit": "s" },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 39 },
      "id": 23,
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(db_query_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(db_query_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(db_query_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p99",
          "refId": "C"
        }
      ],
      "title": "Overall DB Latency Percentiles",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "unit": "short" },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 39 },
      "id": 24,
      "targets": [
        {
          "expr": "sum(db_errors_total)",
          "legendFormat": "Total DB Errors",
          "refId": "A"
        }
      ],
      "title": "Cumulative DB Errors",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 47 },
      "id": 103,
      "title": "Background Worker",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "unit": "s" },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 48 },
      "id": 30,
      "targets": [
        {
          "expr": "rate(worker_cycle_duration_seconds_sum[5m]) / rate(worker_cycle_duration_seconds_count[5m])",
          "legendFormat": "Avg Cycle Duration",
          "refId": "A"
        }
      ],
      "title": "Worker Avg Cycle Duration",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "unit": "short" },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 48 },
      "id": 31,
      "targets": [
        {
          "expr": "rate(worker_cycles_total[5m])",
          "legendFormat": "Cycles/s",
          "refId": "A"
        },
        {
          "expr": "rate(worker_expired_found_total[5m])",
          "legendFormat": "Expired Found/s",
          "refId": "B"
        }
      ],
      "title": "Worker Cycles & Expired Items Rate",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "unit": "short" },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 48 },
      "id": 32,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        { "expr": "worker_cycles_total", "legendFormat": "Total Cycles", "refId": "A" },
        { "expr": "worker_expired_found_total", "legendFormat": "Total Expired Found", "refId": "B" },
        { "expr": "waste_organic_auto_cancels_total", "legendFormat": "Total Auto-Canceled", "refId": "C" }
      ],
      "title": "Worker Cumulative Stats",
      "type": "stat"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 56 },
      "id": 104,
      "title": "Go Runtime",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "unit": "short", "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 100 }, { "color": "red", "value": 500 }] } },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 57 },
      "id": 40,
      "targets": [
        { "expr": "go_goroutines", "legendFormat": "Goroutines", "refId": "A" }
      ],
      "title": "Goroutines",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "unit": "bytes" },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 57 },
      "id": 41,
      "targets": [
        { "expr": "go_memstats_heap_inuse_bytes", "legendFormat": "Heap In Use", "refId": "A" },
        { "expr": "go_memstats_heap_alloc_bytes", "legendFormat": "Heap Alloc", "refId": "B" },
        { "expr": "go_memstats_sys_bytes", "legendFormat": "Sys", "refId": "C" }
      ],
      "title": "Go Memory Usage",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "unit": "ops" },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 57 },
      "id": 42,
      "targets": [
        { "expr": "rate(go_gc_duration_seconds_count[5m])", "legendFormat": "GC Frequency", "refId": "A" },
        { "expr": "rate(go_memstats_mallocs_total[5m])", "legendFormat": "Allocs/s", "refId": "B" }
      ],
      "title": "GC Frequency & Allocations",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "unit": "s" },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 65 },
      "id": 43,
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(go_gc_duration_seconds_bucket[5m]))",
          "legendFormat": "GC p95",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.99, rate(go_gc_duration_seconds_bucket[5m]))",
          "legendFormat": "GC p99",
          "refId": "B"
        }
      ],
      "title": "GC Pause Duration Percentiles",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "unit": "bytes" },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 65 },
      "id": 44,
      "targets": [
        { "expr": "go_memstats_heap_idle_bytes", "legendFormat": "Heap Idle", "refId": "A" },
        { "expr": "go_memstats_stack_inuse_bytes", "legendFormat": "Stack In Use", "refId": "B" },
        { "expr": "go_memstats_mspan_inuse_bytes", "legendFormat": "MSpan In Use", "refId": "C" }
      ],
      "title": "Go Memory Detail",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 73 },
      "id": 105,
      "title": "Process & Infrastructure",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "unit": "percentunit" },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 74 },
      "id": 50,
      "targets": [
        { "expr": "rate(process_cpu_seconds_total[5m])", "legendFormat": "CPU Usage", "refId": "A" }
      ],
      "title": "Process CPU Usage",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "unit": "bytes" },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 74 },
      "id": 51,
      "targets": [
        { "expr": "process_resident_memory_bytes", "legendFormat": "Resident Memory", "refId": "A" },
        { "expr": "process_virtual_memory_bytes", "legendFormat": "Virtual Memory", "refId": "B" }
      ],
      "title": "Process Memory",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "unit": "short" },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 74 },
      "id": 52,
      "targets": [
        { "expr": "process_open_fds", "legendFormat": "Open FDs", "refId": "A" },
        { "expr": "process_max_fds", "legendFormat": "Max FDs", "refId": "B" }
      ],
      "title": "File Descriptors",
      "type": "timeseries"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["waste-collection", "api", "go"],
  "templating": {
    "list": [
      {
        "current": {},
        "hide": 0,
        "includeAll": false,
        "name": "datasource",
        "options": [],
        "query": "prometheus",
        "refresh": 1,
        "type": "datasource"
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Waste Collection API",
  "uid": "waste-collection-api",
  "version": 1
}
