{
  "__inputs": [],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "11.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" }
  ],
  "annotations": { "list": [] },
  "description": "Business KPIs: pickup funnel, payment funnel, error breakdown, and S3 storage metrics.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 200,
      "title": "Pickup Funnel",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "unit": "short", "color": { "fixedColor": "blue", "mode": "fixed" } },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 1 },
      "id": 201,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        { "expr": "sum(waste_pickups_created_total)", "legendFormat": "", "refId": "A" }
      ],
      "title": "Total Pickups Created",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "unit": "short", "color": { "fixedColor": "green", "mode": "fixed" } },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 1 },
      "id": 202,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        { "expr": "sum(waste_pickups_completed_total)", "legendFormat": "", "refId": "A" }
      ],
      "title": "Total Pickups Completed",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "unit": "short", "color": { "fixedColor": "orange", "mode": "fixed" } },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 1 },
      "id": 203,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        { "expr": "sum(waste_pickups_canceled_total)", "legendFormat": "", "refId": "A" }
      ],
      "title": "Total Pickups Canceled",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "unit": "short", "color": { "fixedColor": "red", "mode": "fixed" } },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 1 },
      "id": 204,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        { "expr": "sum(waste_organic_auto_cancels_total)", "legendFormat": "", "refId": "A" }
      ],
      "title": "Organic Auto-Cancels",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "unit": "percentunit", "min": 0, "max": 1, "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "yellow", "value": 0.5 }, { "color": "green", "value": 0.8 }] } },
        "overrides": []
      },
      "gridPos": { "h": 6, "w": 8, "x": 0, "y": 5 },
      "id": 205,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "background" },
      "targets": [
        {
          "expr": "sum(waste_pickups_completed_total) / sum(waste_pickups_created_total)",
          "legendFormat": "Completion Rate",
          "refId": "A"
        }
      ],
      "title": "Pickup Completion Rate",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "unit": "percentunit", "min": 0, "max": 1, "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 0.1 }, { "color": "red", "value": 0.2 }] } },
        "overrides": []
      },
      "gridPos": { "h": 6, "w": 8, "x": 8, "y": 5 },
      "id": 206,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "background" },
      "targets": [
        {
          "expr": "sum(waste_pickups_canceled_total) / sum(waste_pickups_created_total)",
          "legendFormat": "Cancellation Rate",
          "refId": "A"
        }
      ],
      "title": "Pickup Cancellation Rate",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "unit": "reqps", "color": { "mode": "palette-classic" } },
        "overrides": []
      },
      "gridPos": { "h": 6, "w": 8, "x": 16, "y": 5 },
      "id": 207,
      "options": { "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "sum(rate(waste_pickups_created_total[5m])) by (type)",
          "legendFormat": "Created ({{type}})",
          "refId": "A"
        },
        {
          "expr": "sum(rate(waste_pickups_completed_total[5m])) by (type)",
          "legendFormat": "Completed ({{type}})",
          "refId": "B"
        },
        {
          "expr": "sum(rate(waste_pickups_canceled_total[5m])) by (type, reason)",
          "legendFormat": "Canceled ({{type}}/{{reason}})",
          "refId": "C"
        }
      ],
      "title": "Pickup Event Rates by Type",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 11 },
      "id": 210,
      "title": "Payment Funnel",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "unit": "short", "color": { "fixedColor": "blue", "mode": "fixed" } },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 8, "x": 0, "y": 12 },
      "id": 211,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        { "expr": "waste_payments_created_total", "legendFormat": "", "refId": "A" }
      ],
      "title": "Total Payments Created",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "unit": "short", "color": { "fixedColor": "green", "mode": "fixed" } },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 8, "x": 8, "y": 12 },
      "id": 212,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        { "expr": "waste_payments_confirmed_total", "legendFormat": "", "refId": "A" }
      ],
      "title": "Total Payments Confirmed",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "unit": "percentunit", "min": 0, "max": 1, "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "yellow", "value": 0.5 }, { "color": "green", "value": 0.8 }] } },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 8, "x": 16, "y": 12 },
      "id": 213,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "targets": [
        {
          "expr": "waste_payments_confirmed_total / waste_payments_created_total",
          "legendFormat": "Confirmation Rate",
          "refId": "A"
        }
      ],
      "title": "Payment Confirmation Rate",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "unit": "reqps", "color": { "mode": "palette-classic" } },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "id": 214,
      "options": { "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "rate(waste_payments_created_total[5m])",
          "legendFormat": "Payments Created/s",
          "refId": "A"
        },
        {
          "expr": "rate(waste_payments_confirmed_total[5m])",
          "legendFormat": "Payments Confirmed/s",
          "refId": "B"
        }
      ],
      "title": "Payment Created vs Confirmed Rate",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "unit": "reqps", "color": { "mode": "palette-classic" } },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "id": 215,
      "options": { "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "rate(http_requests_total{status=\"429\"}[5m])",
          "legendFormat": "Rate Limit Rejections/s",
          "refId": "A"
        }
      ],
      "title": "Rate Limit Rejections (429/s)",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 24 },
      "id": 220,
      "title": "Error Breakdown",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "unit": "reqps", "color": { "mode": "palette-classic" } },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 25 },
      "id": 221,
      "options": { "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{status=~\"4..\"}[5m])) by (path, status)",
          "legendFormat": "{{status}} {{path}}",
          "refId": "A"
        }
      ],
      "title": "4xx Client Errors by Endpoint",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "unit": "reqps", "color": { "mode": "palette-classic" } },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 25 },
      "id": 222,
      "options": { "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{status=~\"5..\"}[5m])) by (path)",
          "legendFormat": "5xx {{path}}",
          "refId": "A"
        }
      ],
      "title": "5xx Server Errors by Endpoint",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "unit": "s", "color": { "mode": "palette-classic" } },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 25 },
      "id": 223,
      "options": { "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "topk(5, histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket[5m])) by (le, path)))",
          "legendFormat": "p95 {{path}}",
          "refId": "A"
        }
      ],
      "title": "Top 5 Slow Endpoints (p95 Latency)",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 33 },
      "id": 230,
      "title": "S3 Storage",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "unit": "s", "color": { "mode": "palette-classic" } },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 34 },
      "id": 231,
      "options": { "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(s3_upload_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p95",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.50, sum(rate(s3_upload_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p50",
          "refId": "B"
        }
      ],
      "title": "S3 Upload Latency Percentiles",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "unit": "Bps", "color": { "mode": "palette-classic" } },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 34 },
      "id": 232,
      "targets": [
        {
          "expr": "rate(s3_upload_bytes_total[5m])",
          "legendFormat": "Upload Bytes/s",
          "refId": "A"
        }
      ],
      "title": "S3 Upload Throughput (bytes/s)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "unit": "reqps", "color": { "mode": "palette-classic" } },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 34 },
      "id": 233,
      "targets": [
        {
          "expr": "rate(s3_errors_total[5m])",
          "legendFormat": "S3 Errors/s",
          "refId": "A"
        }
      ],
      "title": "S3 Error Rate",
      "type": "timeseries"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["waste-collection", "business", "kpi"],
  "templating": {
    "list": [
      {
        "current": {},
        "hide": 0,
        "includeAll": false,
        "name": "datasource",
        "options": [],
        "query": "prometheus",
        "refresh": 1,
        "type": "datasource"
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Business Operations",
  "uid": "business-operations",
  "version": 1
}
